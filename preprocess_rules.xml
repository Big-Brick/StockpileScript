	<stage id="3" name="technical_normalization">
		<rule id="series_km_letters_to_cyrillic" enabled="true" element_types="capacitor">
			<description>Normalize Latin lookalike K/M in КМ capacitor-like designations without changing unrelated text</description>
			<pattern>\b[КK][МM](?=[\s\-]*\d)</pattern>
			<replacement>КМ</replacement>
		</rule>
		<rule id="km_series_hyphenation" enabled="true" element_types="capacitor">
			<description>Normalize КМ ceramic capacitor series spelling with missing separators</description>
			<pattern>\bКМ[\s\-]*(\d+[а-яА-Яa-zA-Z]?)[\s\-]*([НHМMПP][\s\-]*\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>КМ-$1-$2</replacement>
		</rule>
		<rule id="km_subtype_latin_a_to_cyrillic" enabled="true" element_types="capacitor">
			<description>Normalize Latin a/A to lowercase Cyrillic а in КМ subtype like КМ-5a-Н90</description>
			<pattern>\bКМ-(\d+)a(?=-)</pattern>
			<replacement>КМ-$1а</replacement>
		</rule>
		<rule id="km_subtype_latin_b_to_cyrillic" enabled="true" element_types="capacitor">
			<description>Normalize Latin b/B to lowercase Cyrillic б in КМ subtype like КМ-5b-Н90</description>
			<pattern>\bКМ-(\d+)b(?=-)</pattern>
			<replacement>КМ-$1б</replacement>
		</rule>
		<rule id="km_subtype_cyrillic_a_to_lowercase" enabled="true" element_types="capacitor">
			<description>Normalize Cyrillic А to lowercase а in КМ subtype like КМ-5А-Н90</description>
			<pattern>\bКМ-(\d+)А(?=-)</pattern>
			<replacement>КМ-$1а</replacement>
		</rule>
		<rule id="km_subtype_cyrillic_b_to_lowercase" enabled="true" element_types="capacitor">
			<description>Normalize Cyrillic Б to lowercase б in КМ subtype like КМ-5Б-Н90</description>
			<pattern>\bКМ-(\d+)Б(?=-)</pattern>
			<replacement>КМ-$1б</replacement>
		</rule>
		<rule id="km_temperature_remove_internal_space" enabled="true" element_types="capacitor">
			<description>Remove accidental space inside КМ temperature group after Н/М/П</description>
			<pattern>\b(КМ-\d+[а-яА-Яa-zA-Z]?-[НHМMПP])\s+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>$1$2</replacement>
		</rule>
		<rule id="km_temperature_h_to_cyrillic" enabled="true" element_types="capacitor">
			<description>Normalize Latin H to Cyrillic Н in КМ temperature group</description>
			<pattern>\bКМ-(\d+[а-яА-Яa-zA-Z]?)-H([\s\-]*\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>КМ-$1-Н$2</replacement>
		</rule>
		<rule id="km_temperature_m_to_cyrillic" enabled="true" element_types="capacitor">
			<description>Normalize Latin M to Cyrillic М in КМ temperature group</description>
			<pattern>\bКМ-(\d+[а-яА-Яa-zA-Z]?)-M([\s\-]*\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>КМ-$1-М$2</replacement>
		</rule>
		<rule id="km_temperature_p_to_cyrillic" enabled="true" element_types="capacitor">
			<description>Normalize Latin P to Cyrillic П in КМ temperature group</description>
			<pattern>\bКМ-(\d+[а-яА-Яa-zA-Z]?)-P([\s\-]*\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>КМ-$1-П$2</replacement>
		</rule>
		<rule id="capacitor_k_prefix_space_hyphenation" enabled="true" element_types="capacitor">
			<description>Normalize К-series capacitor designations with a space after К, e.g. К 50 6 to К50-6</description>
			<pattern>\b[КK]\s+(10|15|22|31|40|41|42|50|52|53|57|71|72|73|75|76|77|78)[\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>К$1-$2</replacement>
		</rule>
		<rule id="capacitor_k_series_hyphenation" enabled="true" element_types="capacitor">
			<description>Normalize common К-series capacitor designations such as К10 17 to К10-17</description>
			<pattern>\b[КK](10|15|22|31|40|41|42|50|52|53|71|72|73|75|76|77|78)[\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>К$1-$2</replacement>
		</rule>
		<rule id="resistor_mlt_hyphenation" enabled="true" element_types="resistor">
			<description>Normalize МЛТ/ОМЛТ resistor designations with rating separated by whitespace</description>
			<pattern>\b([ОO]?[МM][ЛL][ТT])[\s\-]+(\d+(?:[,.]\d+)?)(?=\b|[\s\-])</pattern>
			<replacement>$1-$2</replacement>
		</rule>
		<rule id="resistor_omlt_letters_to_cyrillic" enabled="true" element_types="resistor">
			<description>Normalize Latin lookalikes in ОМЛТ resistor prefix</description>
			<pattern>\b[ОO][МM][ЛL][ТT](?=-)</pattern>
			<replacement>ОМЛТ</replacement>
		</rule>
		<rule id="resistor_mlt_letters_to_cyrillic" enabled="true" element_types="resistor">
			<description>Normalize Latin lookalikes in МЛТ resistor prefix</description>
			<pattern>\b[МM][ЛL][ТT](?=-)</pattern>
			<replacement>МЛТ</replacement>
		</rule>
		<rule id="resistor_sp_prefix_space_hyphenation" enabled="true" element_types="resistor">
			<description>Normalize СП resistor designations with split СП/series groups, e.g. СП 5 16 to СП5-16</description>
			<pattern>\b[СC][\s\-]*[ПP]\s*(\d+)[\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>СП$1-$2</replacement>
		</rule>
		<rule id="resistor_sp_hyphenation" enabled="true" element_types="resistor">
			<description>Normalize СП variable resistor series spelling such as СП5 16 to СП5-16</description>
			<pattern>\b[СC][ПP](\d+)[\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>СП$1-$2</replacement>
		</rule>
		<rule id="resistor_s_prefix_space_hyphenation" enabled="true" element_types="resistor">
			<description>Normalize С-series resistor designations with a space after С, e.g. С 2 14 to С2-14</description>
			<pattern>\b[СC]\s+(1|2|3|5|6)[\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>С$1-$2</replacement>
		</rule>
		<rule id="resistor_s_series_hyphenation" enabled="true" element_types="resistor">
			<description>Normalize С1/С2/С5 fixed resistor series spelling such as С2 14 to С2-14</description>
			<pattern>\b[СC](1|2|5|6)[\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>С$1-$2</replacement>
		</rule>
		<rule id="diode_2d_prefix_join" enabled="true" element_types="diode">
			<description>Join 2Д diode prefixes split by whitespace</description>
			<pattern>\b2\s*[ДD][\s\-]*(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>2Д$1</replacement>
		</rule>
		<rule id="diode_2s_prefix_join" enabled="true" element_types="diode">
			<description>Join 2С diode/stabilizer prefixes split by whitespace</description>
			<pattern>\b2\s*[СC][\s\-]*(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>2С$1</replacement>
		</rule>
		<rule id="diode_2a_prefix_join" enabled="true" element_types="diode">
			<description>Join 2А diode prefixes split by whitespace</description>
			<pattern>\b2\s*[АA][\s\-]*(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>2А$1</replacement>
		</rule>
		<rule id="diode_3i_prefix_join" enabled="true" element_types="diode">
			<description>Join 3И diode prefixes split by whitespace</description>
			<pattern>\b3\s*[ИI][\s\-]*(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>3И$1</replacement>
		</rule>
		<rule id="diode_kd_join" enabled="true" element_types="diode">
			<description>Normalize КД diode designations split by whitespace</description>
			<pattern>\b[КK][ДD][\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>КД$1</replacement>
		</rule>
		<rule id="diode_kc_join" enabled="true" element_types="diode">
			<description>Normalize КС stabilizer diode designations split by whitespace</description>
			<pattern>\b[КK][СC][\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>КС$1</replacement>
		</rule>
		<rule id="diode_kc_bridge_join" enabled="true" element_types="diode">
			<description>Normalize КЦ diode bridge designations split by whitespace</description>
			<pattern>\b[КK][Ц][\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>КЦ$1</replacement>
		</rule>
		<rule id="led_al_join" enabled="true" element_types="diode">
			<description>Normalize АЛ LED designations split by whitespace</description>
			<pattern>\b[АA][ЛL][\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>АЛ$1</replacement>
		</rule>
		<rule id="diode_d_series_join" enabled="true" element_types="diode">
			<description>Normalize common Д-series diode designations split by whitespace</description>
			<pattern>\b[ДD][\s\-]+(\d{1,4})\b</pattern>
			<replacement>Д$1</replacement>
		</rule>
		<rule id="diode_d_trailing_letter_join" enabled="true" element_types="diode">
			<description>Remove accidental space before the trailing letter in Д-series diode designations</description>
			<pattern>\b(Д\d{1,4})\s+([а-яА-Яa-zA-Z])\b</pattern>
			<replacement>$1$2</replacement>
		</rule>
		<rule id="semiconductor_trailing_letter_join" enabled="true" element_types="diode,transistor,dinistor,thyristor">
			<description>Remove accidental space before trailing letters in common semiconductor designations</description>
			<pattern>\b((?:КД|КС|КЦ|АЛ|КТ|ГТ|МП|КП|КН|КУ|П)\d{1,4})\s+([а-яА-Яa-zA-Z])\b</pattern>
			<replacement>$1$2</replacement>
		</rule>
		<rule id="transistor_numeric_t_prefix_join" enabled="true" element_types="transistor">
			<description>Join numeric Т transistor prefixes, e.g. 2 Т 312 to 2Т312</description>
			<pattern>\b([12])\s*[ТT][\s\-]*(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>$1Т$2</replacement>
		</rule>
		<rule id="transistor_kt_join" enabled="true" element_types="transistor">
			<description>Normalize КТ transistor designations split by whitespace</description>
			<pattern>\b[КK][ТT][\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>КТ$1</replacement>
		</rule>
		<rule id="transistor_gt_join" enabled="true" element_types="transistor">
			<description>Normalize ГТ transistor designations split by whitespace</description>
			<pattern>\b[ГG][ТT][\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>ГТ$1</replacement>
		</rule>
		<rule id="transistor_mp_join" enabled="true" element_types="transistor">
			<description>Normalize МП transistor designations split by whitespace</description>
			<pattern>\b[МM][ПP][\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>МП$1</replacement>
		</rule>
		<rule id="transistor_kp_join" enabled="true" element_types="transistor">
			<description>Normalize КП field transistor designations split by whitespace</description>
			<pattern>\b[КK][ПP][\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>КП$1</replacement>
		</rule>
		<rule id="dinistor_kn_join" enabled="true" element_types="dinistor">
			<description>Normalize КН dinistor / diode-thyristor designations split by whitespace</description>
			<pattern>\b[КK][НH][\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>КН$1</replacement>
		</rule>
		<rule id="thyristor_2u_prefix_join" enabled="true" element_types="thyristor">
			<description>Join 2У thyristor prefixes split by whitespace</description>
			<pattern>\b2\s*[УY][\s\-]*(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>2У$1</replacement>
		</rule>
		<rule id="thyristor_ku_join" enabled="true" element_types="thyristor">
			<description>Normalize КУ thyristor designations split by whitespace</description>
			<pattern>\b[КK][УY][\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>КУ$1</replacement>
		</rule>
		<rule id="transistor_old_p_join" enabled="true" element_types="transistor">
			<description>Normalize old П-series transistor designations split by whitespace</description>
			<pattern>\b[ПP][\s\-]+([1-4]\d{1,2}[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>П$1</replacement>
		</rule>
		<rule id="microchip_prefix_space_join" enabled="true" element_types="microchip">
			<description>Remove accidental space after microchip prefix, e.g. к 155ИД3 to к155ИД3</description>
			<pattern>\b([КK][РPМM]?|[КK][МM])\s+(\d{3,4}[А-ЯA-Z]{1,4}\d{1,3}[А-ЯA-Z]?)\b</pattern>
			<replacement>$1$2</replacement>
		</rule>
		<rule id="microchip_join_series_function" enabled="true" element_types="microchip">
			<description>Normalize Soviet IC designations split by spaces, e.g. КР 580 ВН 59 А</description>
			<pattern>\b([КK][РPМM]?|[КK]М)?[\s\-]*(\d{3,4})[\s\-]+([А-ЯA-Z]{1,4})[\s\-]*(\d{1,3})[\s\-]*([А-ЯA-Z]?)\b</pattern>
			<replacement>$1$2$3$4$5</replacement>
		</rule>
		<rule id="microchip_prefix_kr_to_cyrillic" enabled="true" element_types="microchip">
			<description>Normalize Latin lookalikes in КР microchip prefix</description>
			<pattern>\b[КK][РP](?=\d{3,4})</pattern>
			<replacement>КР</replacement>
		</rule>
		<rule id="microchip_prefix_km_to_cyrillic" enabled="true" element_types="microchip">
			<description>Normalize Latin lookalikes in КМ microchip prefix before IC series digits</description>
			<pattern>\b[КK][МM](?=\d{3,4})</pattern>
			<replacement>КМ</replacement>
		</rule>
		<rule id="microchip_prefix_k_to_cyrillic" enabled="true" element_types="microchip">
			<description>Normalize Latin K to Cyrillic К before IC series digits</description>
			<pattern>\bK(?=\d{3,4}[А-ЯA-Z])</pattern>
			<replacement>К</replacement>
		</rule>
		<rule id="relay_res_hyphenation" enabled="true" element_types="relay">
			<description>Normalize РЕС relay series spelling and hyphenation after language normalization</description>
			<pattern>\bРЕС[\s\-]*(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>РЕС-$1</replacement>
		</rule>
		<rule id="relay_ren_hyphenation" enabled="true" element_types="relay">
			<description>Normalize РЕН relay series spelling and hyphenation after language normalization</description>
			<pattern>\bРЕН[\s\-]*(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>РЕН-$1</replacement>
		</rule>
		<rule id="connector_2rm_hyphenation" enabled="true" element_types="connector">
			<description>Normalize 2РМ connector series with missing separator</description>
			<pattern>\b2[РP][МM][\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>2РМ-$1</replacement>
		</rule>
		<rule id="connector_grpm_hyphenation" enabled="true" element_types="connector">
			<description>Normalize ГРПМ connector series with missing separator</description>
			<pattern>\b[ГG][РP][ПP][МM][\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>ГРПМ-$1</replacement>
		</rule>
		<rule id="connector_snp_hyphenation" enabled="true" element_types="connector">
			<description>Normalize СНП connector series with missing separator</description>
			<pattern>\b[СC][НH][ПP](\d*)[\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>СНП$1-$2</replacement>
		</rule>
		<rule id="connector_onp_kg_case" enabled="true" element_types="connector">
			<description>Normalize ОНп-КГ connector family spelling</description>
			<pattern>\b[ОO][НH][ПP][\s\-]*[КK][ГG]\b</pattern>
			<replacement>ОНп-КГ</replacement>
		</rule>
		<rule id="connector_onp_kg_hyphenation" enabled="true" element_types="connector">
			<description>Normalize ОНп-КГ connector numeric groups with missing separators</description>
			<pattern>\bОНп-КГ[\s\-]+(\d+)[\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>ОНп-КГ-$1-$2</replacement>
		</rule>
		<rule id="switch_p2k_hyphenation" enabled="true" element_types="switch">
			<description>Normalize П2К switch series with missing separator</description>
			<pattern>\b[ПP]2[КK][\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>П2К-$1</replacement>
		</rule>
		<rule id="transformer_tpp_hyphenation" enabled="true" element_types="transformer">
			<description>Normalize ТПП transformer series with missing separator</description>
			<pattern>\b[ТT][ПP][ПP][\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>ТПП-$1</replacement>
		</rule>
		<rule id="resonator_rk_hyphenation" enabled="true" element_types="resonator">
			<description>Normalize РК quartz resonator series with missing separator</description>
			<pattern>\b[РP][КK][\s\-]*(\d{2,4}[а-яА-Яa-zA-Z]*)[\s\-]+(\d+[а-яА-Яa-zA-Z]*)\b</pattern>
			<replacement>РК$1-$2</replacement>
		</rule>
		<rule id="remove_spaces_around_hyphen" enabled="true">
			<description>Remove accidental spaces around hyphen inside technical designations</description>
			<pattern>\s+\-\s+|\s+\-|\-\s+</pattern>
			<replacement>-</replacement>
		</rule>
		<rule id="collapse_spaces_before_common_units" enabled="true">
			<description>Remove accidental space between value and common unit abbreviations</description>
			<pattern>\b(\d+(?:[,.]\d+)?)\s\s+(кОм|КОм|Ом|МОм|мкФ|нФ|пФ|В|А)\b</pattern>
			<replacement>$1 $2</replacement>
		</rule>
	</stage>
</xlsx_preprocess_rules>