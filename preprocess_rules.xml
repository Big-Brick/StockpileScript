<?xml version='1.0' encoding='utf-8'?>
<xlsx_preprocess_rules version="1">
	<ignored_texts>
		<pattern id="board_plate_word" enabled="true" description="Rows containing board/PCB word плат-а/и/і/у/... variations">\bплат(а|и|і|у|ою|ею|ах|ами|ам)?\b</pattern>
		<pattern id="generic_context_word_pair" enabled="true" description="Rows containing at least two separate context words that cannot be an element designation">(?=.*\b(?:складі|стійці|розташовані|н[іи]й|ньому|якому|якій|яких|який|яка|яке|цей|цьому|цій)\b)\b(?:на|у|в|складі|стійці|розташовані|н[іи]й|ньому|якому|якій|яких|який|яка|яке|де|що|цей|ця|це|цьому|цій)\b.*\b(?:на|у|в|складі|стійці|розташовані|н[іи]й|ньому|якому|якій|яких|який|яка|яке|де|що|цей|ця|це|цьому|цій)\b</pattern>
		<pattern id="generic_missing_marker" enabled="true" description="Rows containing explicit missing/excluded wording">\b(відсутн[іи]|немає|відсутнє|без)\b</pattern>
		<pattern id="generic_safe_ignore_words" enabled="true" description="Rows containing safe non-element words крім/того/розміщені variants">\b(о?крім\w*|того|розміщен\w*)\b</pattern>
		<pattern id="generic_military_rank" enabled="true" description="Rows containing Ukrainian military rank words">\b(\s*працівник\s*ЗСУ\w*|\s*прац\.\s*ЗСУ\w*|\s*пр\.\s*ЗСУ\w*|рекрут\w*|солдат\w*|сержант\w*|старшин\w*|прапорщик\w*|лейтенант\w*|капітан\w*|майор\w*|підполковник\w*|полковник\w*|генерал\w*)\b</pattern>
		<pattern id="generic_commission" enabled="true" description="Rows containing commission wording">\bкомісі\w*\b</pattern>
		<pattern id="generic_completeness" enabled="true" description="Rows containing completeness/complectation wording">\b(комплектн\w*|комплектаці\w*)\b</pattern>
		<pattern id="autogenerated_calculated_by" enabled="true" description="Autogenerated less-safe ignored text: calculation signature row" source="autogenerated" safety="less_safe">(?iu)^\s*Підрахунок здійснили:.*$</pattern>
		<pattern id="autogenerated_available_property_heading" enabled="true" description="Autogenerated less-safe ignored text: available property heading" source="autogenerated" safety="less_safe">(?iu)^\s*Найменування наявного майна та комплектуючих\s*$</pattern>
		<pattern id="autogenerated_documentation_reference" enabled="true" description="Autogenerated less-safe ignored text: documentation reference" source="autogenerated" safety="less_safe">(?iu)^\s*згідно документації\s*$</pattern>
		<pattern id="autogenerated_blank_signature_date" enabled="true" description="Autogenerated less-safe ignored text: blank signature date" source="autogenerated" safety="less_safe">(?iu)^\s*_{2,}\._{2,}\.\d{4}\s*$</pattern>
		<pattern id="autogenerated_empty_context_marker" enabled="true" description="Autogenerated less-safe ignored text: empty context marker" source="autogenerated" safety="less_safe">(?iu)^\s*(?:Навісом|У\s*нь?ому|Уньому)\s*:?\s*$</pattern>
		<pattern id="autogenerated_block_rows" enabled="true" description="Autogenerated less-safe ignored text: block rows" source="autogenerated" safety="less_safe">(?iu)^\s*(?:Блок|блок|БЖ)\b.*$</pattern>
		<pattern id="autogenerated_rack_rows" enabled="true" description="Autogenerated less-safe ignored text: rack rows" source="autogenerated" safety="less_safe">(?iu)^\s*Стійк[аи]\b.*$</pattern>
		<pattern id="autogenerated_product_lab_rows" enabled="true" description="Autogenerated less-safe ignored text: product/lab rows" source="autogenerated" safety="less_safe">(?iu)^\s*(?:Виріб|Лабораторія)\b.*$</pattern>
		<pattern id="autogenerated_cell_rows" enabled="true" description="Autogenerated less-safe ignored text: cell/chamber rows" source="autogenerated" safety="less_safe">(?iu)^\s*(?:Комірка|Чарунка)\b.*$</pattern>
		<pattern id="autogenerated_computer_part_rows" enabled="true" description="Autogenerated less-safe ignored text: computer part rows" source="autogenerated" safety="less_safe">(?iu)^\s*(?:Системний\s+блок|Монітор|Клавіатура|ОЗУ)\b.*$</pattern>
		<pattern id="autogenerated_storage_media_rows" enabled="true" description="Autogenerated less-safe ignored text: storage/media rows" source="autogenerated" safety="less_safe">(?iu)^\s*(?:flo+p{1,2}y\s+drive|Дисковод|Привід\s+для\s+дискет|Електроника\s+МС5305\b.*\bFlop\b|Жорсткий\s+диск|Магнітофон)\b.*$</pattern>
		<pattern id="autogenerated_mechanical_optical_rows" enabled="true" description="Autogenerated less-safe ignored text: mechanical/optical rows" source="autogenerated" safety="less_safe">(?iu)^\s*(?:алюм.*короб|Каркас\s+шафи|Корпус\s+з\b|механічна\s+система|Механізм\s+наведення|оптична\s+система|Насадка\s+бінокулярна|антена\b|Антена\b|телефонна\s+гарнітура)\b.*$</pattern>
		<pattern id="autogenerated_motor_display_rows" enabled="true" description="Autogenerated less-safe ignored text: motor/display rows" source="autogenerated" safety="less_safe">(?iu)^\s*(?:Вентилятор|Двигун|АДП\s+\S+.*[эе]лектродв\.?|К[іи]н[еі]скоп|ЭЛТ)\b.*$</pattern>
		<pattern id="autogenerated_device_instrument_rows" enabled="true" description="Autogenerated less-safe ignored text: device/instrument rows" source="autogenerated" safety="less_safe">(?iu)^\s*(?:Ампермети?р|Вольтмети?р|Мегоометр|Прибор\s+комбінований|Перетворювач|Пристрій\b|Пост\s+фотокінодеодолітний|Годинник|Часи|часи|Радіостанція|радіостанція)\b.*$</pattern>
		<pattern id="autogenerated_generic_element_counts" enabled="true" description="Autogenerated less-safe ignored text: generic element-count rows" source="autogenerated" safety="less_safe">(?iu)^\s*(?:(?:[0-9]{2,4}(?:\s+[0-9]{2,4})?|[0-9]+[RК][0-9]+|I?R\d+|[N]|БН)\s+елемент|елемент(?:и)?\s+БН)\s*$</pattern>
		<pattern id="autogenerated_transformers_heading" enabled="true" description="Autogenerated less-safe ignored text: transformers heading" source="autogenerated" safety="less_safe">(?iu)^\s*Трансформатори\s*$</pattern>
	</ignored_texts>
	<settings>
		<regex_flags ignore_case="true" unicode="true" />
		<whitespace collapse="true" trim="true" />
	</settings>
	<stage id="1" name="language_normalization">
		<rule id="ru_relay_res_series" enabled="true">
			<description>Russian РЭС relay spelling to Ukrainian РЕС for relay series designations</description>
			<pattern>\bРЭ([СНКВ])(?=\b|[\s\-]*\d)</pattern>
			<replacement>РЕ$1</replacement>
		</rule>
		<rule id="ru_relay_res_standalone_latin_lookalikes" enabled="true">
			<description>РЭС/РEС written with Latin lookalike letters to РЕС</description>
			<pattern>\b[РP][ЭE][СC]\b</pattern>
			<replacement>РЕС</replacement>
		</rule>
		<rule id="ru_connector_word" enabled="true">
			<description>Russian connector type word to Ukrainian canonical word</description>
			<pattern>\bразъ[её]м\b</pattern>
			<replacement>Роз'єм</replacement>
		</rule>
		<rule id="uk_connector_word_mixed_spelling" enabled="true">
			<description>Mixed Ukrainian/Russian connector spelling without apostrophe to Ukrainian canonical word</description>
			<pattern>\bроз[ьъ]?ем\b|\bрозєм\b</pattern>
			<replacement>Роз'єм</replacement>
		</rule>
		<rule id="ru_microchip_word" enabled="true">
			<description>Russian microchip type word to Ukrainian canonical word</description>
			<pattern>\bмикросхем[аыу]?\b</pattern>
			<replacement>Мікросхема</replacement>
		</rule>
		<rule id="ru_switch_word" enabled="true">
			<description>Russian switch type word to Ukrainian canonical word</description>
			<pattern>\bпереключател[ьяи]?\b</pattern>
			<replacement>Перемикач</replacement>
		</rule>
		<rule id="ru_transformer_word" enabled="true">
			<description>Russian transformer type word to Ukrainian canonical word</description>
			<pattern>\bтрансформатор[аы]?\b</pattern>
			<replacement>Трансформатор</replacement>
		</rule>
		<rule id="ru_inductor_choke_word" enabled="true">
			<description>Russian choke/inductor type word to Ukrainian inductor type word</description>
			<pattern>\bдроссел[ьяи]?\b</pattern>
			<replacement>Дросель</replacement>
		</rule>
		<rule id="ru_quartz_resonator_word" enabled="true">
			<description>Russian quartz resonator phrase to Ukrainian resonator phrase</description>
			<pattern>\bкварцев[ыо]й\s+резонатор\b</pattern>
			<replacement>Резонатор</replacement>
		</rule>
	</stage>
