<?xml version="1.0" encoding="utf-8"?>
<xlsx_preprocess_rules version="1">

    <ignored_texts>
	    <pattern
		    id="board_contains_placed"
		    enabled="true"
	    	description="Board/block header listing placed or available components">
    		\b(плата|блок|модуль|вузол)\b.*\b(на\s+ньому|на\s+н(і|и)й|де|в\s+якому|у\s+якому)\b.*\b(розміщен[іи]|розташован[іи]|встановлен[іи]|змонтован[іи]|наявн[іи]|присутн[іи])\b
	    </pattern>

    	<pattern
	    	id="board_contains_short"
    		enabled="true"
	    	description="Short board/block header ending with на ній:">
		    \b(плата|блок|модуль|вузол)\b.*\bна\s+н(і|и)й\b\s*:?$
    	</pattern>

	    <pattern
		    id="board_missing_elements"
    		enabled="true"
	    	description="Board/block header listing missing components">
		    \b(плата|блок|модуль|вузол)\b.*\b(відсутн[іи]|немає|відсутнє|без)\b
    	</pattern>

	    <pattern
		    id="board_available_except"
    		enabled="true"
	    	description="Board/block header listing available components except missing ones">
		    \b(плата|блок|модуль|вузол)\b.*\b(в\s+наявності|наявн[іи]|присутн[іи])\b.*\b(за\s+виключенням|за\s+винятком|крім|окрім)\b
    	</pattern>

    	<pattern
	    	id="generic_placed_marker"
		    enabled="true"
    		description="Generic phrase marker for placed/listed contents rows">
	    	\b(на\s+н(і|и)й|на\s+якій|де)\b\s*:?\s*$|\b(на\s+н(і|и)й|на\s+якій|де)\b.*\b(розміщен[іи]|розташован[іи]|встановлен[іи]|змонтован[іи])\b
    	</pattern>

	    <pattern
		    id="generic_missing_marker"
    		enabled="true"
	    	description="Generic phrase marker for missing/excluded contents rows">
		    \b(відсутн[іи]|немає)\b\s*:?$|\b(в\s+наявності|наявн[іи])\b.*\b(за\s+виключенням|за\s+винятком|крім|окрім)\b
    	</pattern>
    </ignored_texts>

    <settings>
        <regex_flags ignore_case="true" unicode="true"/>
        <whitespace collapse="true" trim="true"/>
        <cache auto_update="true"/>

        <!--
            Optional safety metadata for Codex/module implementation.
            These prefixes should not be blindly inserted into ordinary prefix_cache
            without checking all candidate element types, because they are too broad
            or are known to be used in more than one component family.
        -->
        <cache_guards>
            <ambiguous_prefix>КМ</ambiguous_prefix>
            <ambiguous_prefix>К</ambiguous_prefix>
            <ambiguous_prefix>КП</ambiguous_prefix>
            <ambiguous_prefix>П</ambiguous_prefix>
            <ambiguous_prefix>СП</ambiguous_prefix>
            <ambiguous_prefix>РП</ambiguous_prefix>
            <ambiguous_prefix>Д</ambiguous_prefix>
            <ambiguous_prefix>С</ambiguous_prefix>
        </cache_guards>
    </settings>

    <stage id="1" name="language_normalization">
        <rule id="ru_relay_res_series" enabled="true">
            <description>Russian РЭС relay spelling to Ukrainian РЕС for relay series designations</description>
            <pattern>\bРЭ([СНКВ])(?=\b|[\s\-]*\d)</pattern>
            <replacement>РЕ$1</replacement>
        </rule>
        <rule id="ru_relay_res_standalone_latin_lookalikes" enabled="true">
            <description>РЭС/РEС written with Latin lookalike letters to РЕС</description>
            <pattern>\b[РP][ЭE][СC]\b</pattern>
            <replacement>РЕС</replacement>
        </rule>
        <rule id="ru_connector_word" enabled="true">
            <description>Russian connector type word to Ukrainian canonical word</description>
            <pattern>\bразъ[её]м\b</pattern>
            <replacement>Роз'єм</replacement>
        </rule>
        <rule id="uk_connector_word_mixed_spelling" enabled="true">
            <description>Mixed Ukrainian/Russian connector spelling without apostrophe to Ukrainian canonical word</description>
            <pattern>\bроз[ьъ]?ем\b|\bрозєм\b</pattern>
            <replacement>Роз'єм</replacement>
        </rule>
        <rule id="ru_microchip_word" enabled="true">
            <description>Russian microchip type word to Ukrainian canonical word</description>
            <pattern>\bмикросхем[аыу]?\b</pattern>
            <replacement>Мікросхема</replacement>
        </rule>
        <rule id="ru_switch_word" enabled="true">
            <description>Russian switch type word to Ukrainian canonical word</description>
            <pattern>\bпереключател[ьяи]?\b</pattern>
            <replacement>Перемикач</replacement>
        </rule>
        <rule id="ru_transformer_word" enabled="true">
            <description>Russian transformer type word to Ukrainian canonical word</description>
            <pattern>\bтрансформатор[аы]?\b</pattern>
            <replacement>Трансформатор</replacement>
        </rule>
        <rule id="ru_inductor_choke_word" enabled="true">
            <description>Russian choke/inductor type word to Ukrainian inductor type word</description>
            <pattern>\bдроссел[ьяи]?\b</pattern>
            <replacement>Дросель</replacement>
        </rule>
        <rule id="ru_quartz_resonator_word" enabled="true">
            <description>Russian quartz resonator phrase to Ukrainian resonator phrase</description>
            <pattern>\bкварцев[ыо]й\s+резонатор\b</pattern>
            <replacement>Резонатор</replacement>
        </rule>
    </stage>

